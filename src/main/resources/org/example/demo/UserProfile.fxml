                           <GridPane.margin>
                              <Insets right="10.0" top="1.0" />
                           </GridPane.margin></Label>
                         <Label fx:id="DateLabel" alignment="CENTER_RIGHT" prefHeight="17.0" prefWidth="357.0" text="Label" textAlignment="JUSTIFY" textOverrun="CENTER_ELLIPSIS" GridPane.columnIndex="1" GridPane.rowIndex="1">
