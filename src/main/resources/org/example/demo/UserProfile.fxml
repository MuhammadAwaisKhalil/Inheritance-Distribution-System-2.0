<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="600.0" prefWidth="900.0"
        stylesheets="@profile.css"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.demo.User.UserProfileController">

    <!-- ═══════════════════════════════════════════
         TOP NAV BAR
    ════════════════════════════════════════════ -->
    <top>
        <HBox
                alignment="CENTER_LEFT"
                prefHeight="60.0"
                spacing="15.0"
                style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;"
                BorderPane.alignment="CENTER">
            <padding><Insets left="20.0" right="20.0" /></padding>
            <children>

                <Label text="☰" textFill="#515151">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>

                <Label text="User Profile" textFill="#222222">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- User Account Badge -->
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="User Account" textFill="#444444" />
                        <Circle
                                fill="#CFD8DC"
                                radius="16.0"
                                stroke="#90A4AE"
                                strokeType="INSIDE" />
                    </children>
                </HBox>

            </children>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════
         LEFT SIDEBAR
    ════════════════════════════════════════════ -->
    <left>
        <VBox
                prefHeight="540.0"
                prefWidth="190.0"
                spacing="6.0"
                style="-fx-background-color: #2C3E50;"
                BorderPane.alignment="CENTER">
            <padding><Insets top="24.0" left="12.0" right="12.0" bottom="12.0" /></padding>
            <children>

                <!-- Sidebar Header -->
                <Label text="MENU" textFill="#8FA3B1" style="-fx-font-size: 10px; -fx-font-weight: bold;">
                    <padding><Insets left="8.0" bottom="6.0" /></padding>
                </Label>

                <Button
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#goToAnalytics"
                        text="📊  Analytics"
                        textFill="WHITE"
                        style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12;" />

                <Button
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#gotoInheritor"
                        text="👥  Inheritors"
                        textFill="WHITE"
                        style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12;" />

                <Button
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        text="⚙️  Settings"
                        textFill="WHITE"
                        style="-fx-background-color: #34495E; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-background-radius: 6;" />

            </children>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════
         CENTER CONTENT
    ════════════════════════════════════════════ -->
    <center>
        <VBox
                alignment="TOP_CENTER"
                spacing="0"
                style="-fx-background-color: #F7F8FC;"
                BorderPane.alignment="CENTER">

            <!-- Profile Avatar + Name -->
            <VBox
                    alignment="CENTER"
                    spacing="10.0"
                    style="-fx-background-color: #FFFFFF; -fx-border-color: #E8ECF4; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="30.0" bottom="20.0" /></padding>
                <children>
                    <Circle
                            fx:id="imageCircle"
                            fill="#534AB7"
                            radius="52.0"
                            stroke="#C5C0EE"
                            strokeWidth="3.0"
                            strokeType="INSIDE"
                            style="-fx-effect: dropshadow(gaussian, rgba(83,74,183,0.25), 10, 0.3, 0, 3);" />

                    <Label
                            fx:id="accountName"
                            text="Username"
                            style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

                    <Label
                            text="Manage your personal information"
                            style="-fx-font-size: 12px; -fx-text-fill: #8A94A6;" />
                </children>
            </VBox>

            <!-- Form Card -->
            <VBox
                    spacing="0"
                    style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0.2, 0, 4);">
                <padding><Insets top="28.0" bottom="28.0" left="40.0" right="40.0" /></padding>
                <VBox.margin><Insets top="24.0" left="36.0" right="36.0" /></VBox.margin>

                <children>
                    <!-- Section Title -->
                    <Label
                            text="Profile Details"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #534AB7;">
                        <padding><Insets bottom="16.0" /></padding>
                    </Label>

                    <!-- Form Grid -->
                    <GridPane hgap="20.0" vgap="14.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints prefHeight="56.0" />
                            <RowConstraints prefHeight="56.0" />
                            <RowConstraints prefHeight="56.0" />
                        </rowConstraints>
                        <children>

                            <!-- Row 0: Username -->
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <children>
                                    <Label text="Username" style="-fx-font-size: 11px; -fx-text-fill: #8A94A6; -fx-font-weight: bold;" />
                                    <TextField fx:id="userNameTextbox" promptText="Enter username"
                                               style="-fx-background-color: #F4F6FB; -fx-border-color: #D1D5E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12 8 12;" />
                                </children>
                            </VBox>

                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER_RIGHT">
                                <children>
                                    <Label text="CURRENT" style="-fx-font-size: 10px; -fx-text-fill: #B0B8CC; -fx-font-weight: bold;" />
                                    <Label fx:id="userNameLabel" text="—"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                                </children>
                            </VBox>

                            <!-- Row 1: Date of Birth -->
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <children>
                                    <Label text="Date of Birth" style="-fx-font-size: 11px; -fx-text-fill: #8A94A6; -fx-font-weight: bold;" />
                                    <DatePicker fx:id="dateTextBox"
                                                style="-fx-background-color: #F4F6FB; -fx-border-color: #D1D5E8; -fx-border-radius: 6; -fx-background-radius: 6;" />
                                </children>
                            </VBox>

                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1" alignment="CENTER_RIGHT">
                                <children>
                                    <Label text="CURRENT" style="-fx-font-size: 10px; -fx-text-fill: #B0B8CC; -fx-font-weight: bold;" />
                                    <Label fx:id="DateLabel" text="—"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                                </children>
                            </VBox>

                            <!-- Row 2: Email -->
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <children>
                                    <Label text="Email Address" style="-fx-font-size: 11px; -fx-text-fill: #8A94A6; -fx-font-weight: bold;" />
                                    <TextField fx:id="emailTextbox" promptText="Enter email"
                                               style="-fx-background-color: #F4F6FB; -fx-border-color: #D1D5E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12 8 12;" />
                                </children>
                            </VBox>

                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="2" alignment="CENTER_RIGHT">
                                <children>
                                    <Label text="CURRENT" style="-fx-font-size: 10px; -fx-text-fill: #B0B8CC; -fx-font-weight: bold;" />
                                    <Label fx:id="emailLabel" text="—"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                                </children>
                            </VBox>

                        </children>
                    </GridPane>

                    <!-- Divider -->
                    <Region prefHeight="1.0" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #E8ECF4;">
                        <VBox.margin><Insets top="20.0" bottom="20.0" /></VBox.margin>
                    </Region>

                    <!-- Save Button -->
                    <HBox alignment="CENTER_RIGHT">
                        <children>
                            <Button
                                    mnemonicParsing="false"
                                    onAction="#handleSave"
                                    text="Save Changes"
                                    styleClass="primary-btn"
                                    style="-fx-background-color: #534AB7; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 28 10 28; -fx-background-radius: 8; -fx-cursor: hand;" />
                        </children>
                    </HBox>

                </children>
            </VBox>

        </VBox>
    </center>

</BorderPane>