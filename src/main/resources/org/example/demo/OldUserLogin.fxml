<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="451.0" prefWidth="360.0" spacing="20.0" stylesheets="@auth.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.Login.HelloController" styleClass="auth-root">
   <children>
      <VBox alignment="CENTER_LEFT" maxWidth="310.0" spacing="12.0" styleClass="auth-card">
         <padding>
            <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
         </padding>
         <children>
            <Label text="Welcome Back" styleClass="auth-title" />
            <Label text="Email" styleClass="auth-label" />
            <TextField fx:id="usernameField1" promptText="Username" styleClass="auth-field" />
            <Label text="Password" styleClass="auth-label" />
            <PasswordField fx:id="passwordField1" promptText="Password" styleClass="auth-field" />
            <Region prefHeight="8.0" />
            <Button mnemonicParsing="false" onAction="#userLogin" prefWidth="120.0" text="Login" styleClass="auth-primary-btn" />
            <Button mnemonicParsing="false" onAction="#switchToRegister" prefWidth="120.0" text="Register" styleClass="auth-secondary-btn" />
         </children>
      </VBox>
   </children>
</VBox>
