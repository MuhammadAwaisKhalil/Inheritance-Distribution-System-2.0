<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER_LEFT" prefHeight="260.0" prefWidth="340.0" spacing="15.0" stylesheets="@form-popup.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.Property.PropertyPopupController" styleClass="popup-root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Add New Property" styleClass="popup-title" />
        <Label text="Capture property details for analytics and inheritance allocation." styleClass="popup-subtitle" wrapText="true" />

        <VBox spacing="5.0" styleClass="field-group">
            <children>
                <Label text="Property Name" styleClass="field-label" />
                <TextField fx:id="propertyNameField" promptText="e.g. DHA Phase 6" />
            </children>
        </VBox>

        <VBox spacing="5.0" styleClass="field-group">
            <children>
                <Label text="Valuation" styleClass="field-label" />
                <TextField fx:id="valuationField" promptText="e.g. 500000" />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="popup-actions">
            <children>
                <Button mnemonicParsing="false" onAction="#CancelClick" text="Cancel" styleClass="btn-cancel" />
                <Button mnemonicParsing="false" onAction="#doneClick" text="Save" styleClass="btn-primary" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>