<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" prefHeight="250.0" prefWidth="300.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.PropertyPopupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Add New Property">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label text="Property Name:" />
                <TextField fx:id="propertyNameField" promptText="e.g. DHA Phase 6" />
            </children>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label text="Valuation:" />
                <TextField fx:id="valuationField" promptText="e.g. $500,000" />
            </children>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#CancelClick" text="Cancel" />
                <Button mnemonicParsing="false" onAction="#doneClick" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Done" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>