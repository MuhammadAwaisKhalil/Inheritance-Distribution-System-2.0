<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" stylesheets="@inheritors-detail.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.Inheritors.InheritorsDetailController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Menu" textFill="#515151">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label text="Inheritors" textFill="#222222">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="User Account" />
                        <Circle fill="#cfcfcf" radius="15.0" stroke="#9e9e9e" strokeType="INSIDE" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
            <Label styleClass="toolbar-title" text="All Inheritors" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="220" promptText="Search by name or relation…" styleClass="search-field" />
            <ComboBox fx:id="sortCombo" promptText="Sort by" styleClass="sort-combo" />
            <Button onAction="#openAddDialog" styleClass="add-btn" text="+ Add Inheritor" />
            <padding><Insets bottom="14" left="20" right="20" top="14" /></padding>
        </HBox>

    </top>
    <left>
        <VBox prefHeight="540.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #2C3E50;" BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: transparent; " text="Analytics(In detail)" textFill="WHITE" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #34495E" text="Inheritors" textFill="WHITE" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: transparent;" text="Settings" textFill="WHITE" />
            </children>
            <padding>
                <Insets left="15.0" right="15.0" top="20.0" />
            </padding>
        </VBox>
    </left>
    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="worth-bar">
                <Label styleClass="worth-bar-label" text="Total Estate:" />
                <Label fx:id="totalWorthLabel" styleClass="worth-bar-amount" text="PKR 0" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="inheritorCountLabel" styleClass="count-label" text="0 Inheritors" />
                <padding><Insets bottom="10" left="20" right="20" top="10" /></padding>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <Accordion fx:id="inheritorsAccordion" styleClass="inheritors-accordion" />
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
